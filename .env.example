# Copy to .env and fill in your values

# OpenAI (optional - only needed for OpenAI backend)
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Ollama (default: local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma4:e4b-it-qat
OLLAMA_TIMEOUT=300
OLLAMA_PROMPT_MAX_CHARS=6000

# LLM backend: "ollama" or "openai"
LLM_BACKEND=ollama

# Confidence threshold for template match (0.0 - 1.0)
TEMPLATE_MATCH_THRESHOLD=0.75

# How many critical (not_null) fields must be missing before falling back to LLM.
# Set to 1 to be strict, 2-3 to tolerate minor regex failures on repeated docs.
VALIDATION_FALLBACK_THRESHOLD=2

# Absolute or relative path to template store JSON
# Relative paths are anchored to the project root automatically
TEMPLATE_STORE_PATH=templates/store.json

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=doc-schema-extractor
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Debug logging
LOG_LEVEL=DEBUG
LOG_DIR=./logs
LOG_FILE=doc_schema_extractor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_RAW_TEXT_PREVIEW_CHARS=2000

# Audit log (cross-document score tracking)
AUDIT_LOG_PATH=./logs/extraction_audit.jsonl
